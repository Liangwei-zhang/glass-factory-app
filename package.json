{
  "name": "glass-factory-app",
  "version": "1.0.0",
  "description": "Glass Factory Order Management System",
  "main": "backend/server.js",
  "type": "module",
  "scripts": {
    "start": "python3 -m uvicorn apps.public_api.main:app --host 0.0.0.0 --port 8000",
    "start:admin": "python3 -m uvicorn apps.admin_api.main:app --host 0.0.0.0 --port 8001",
    "start:scheduler": "python3 -m apps.scheduler",
    "dev": "python3 -m uvicorn apps.public_api.main:app --host 0.0.0.0 --port 8000 --reload",
    "dev:admin": "python3 -m uvicorn apps.admin_api.main:app --host 0.0.0.0 --port 8001 --reload",
    "legacy:start": "node backend/server.js",
    "legacy:dev": "node --watch backend/server.js",
    "postgres:ping": "node backend/persistence/postgres-client.js",
    "postgres:init": "node scripts/postgres-init.js",
    "postgres:sync": "node scripts/postgres-sync.js"
  },
  "dependencies": {
    "@embedpdf/fonts-sc": "^1.0.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.5",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "uuid": "^9.0.1"
  }
}
