APP_ENV=dev
APP_DEBUG=true
APP_NAME=glass-factory

PUBLIC_API_PREFIX=/v1
ADMIN_API_PREFIX=/v1/admin

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/glass_factory
DATABASE_ECHO=false
DATABASE_USE_NULL_POOL=true
AUTO_INIT_SCHEMA_ON_STARTUP=true

REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50
RATE_LIMIT_STORAGE_URL=memory://
RATE_LIMIT_KEY_PREFIX=glass-factory
RATE_LIMIT_IN_MEMORY_FALLBACK_ENABLED=true

EVENT_BROKER_BACKEND=redis_streams
EVENT_BROKER_REDIS_STREAM=factory.events
EVENT_BROKER_REDIS_STREAM_MAXLEN=50000
EVENT_BROKER_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
EVENT_BROKER_KAFKA_TOPIC=factory.events
EVENT_BROKER_KAFKA_CLIENT_ID=glass-factory-event-pipeline

CLICKHOUSE_BASE_URL=http://localhost:8123
CLICKHOUSE_DATABASE=default

OBJECT_STORAGE_BACKEND=local
OBJECT_STORAGE_LOCAL_DIR=data/object_storage
OBJECT_STORAGE_DOWNLOAD_CACHE_DIR=data/object_storage_cache
OBJECT_STORAGE_S3_ENDPOINT_URL=
OBJECT_STORAGE_S3_REGION=us-east-1
OBJECT_STORAGE_S3_ACCESS_KEY=
OBJECT_STORAGE_S3_SECRET_KEY=
OBJECT_STORAGE_S3_BUCKET=glass-factory
OBJECT_STORAGE_S3_PREFIX=

SCHEDULER_HEARTBEAT_ONLY=false

JWT_SECRET=glass-factory-dev-secret
ACCESS_TOKEN_MINUTES=30

# Optional file-backed secrets (preferred in containers)
# DATABASE_URL_FILE=/run/secrets/app_database_url
# JWT_SECRET_FILE=/run/secrets/app_secret_key

# Legacy Node.js variables kept only for compatibility migrations
# DATABASE_PROVIDER=sqlite
# SQLITE_DATABASE_PATH=
# POSTGRES_DATABASE_URL=
